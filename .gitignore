# secrets
.env
.env.*
!.env.example

# python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# editor / os
.vscode/
.idea/
.DS_Store

# claude code local config — only ignore personal/local pieces,
# agents and shared settings should travel with the repo
.claude/settings.local.json
.claude/*.local.json

# PDFs (too large / redundant with extracted markdown under docs/)
*.pdf

# Build artifacts
dist/

# MPB adapter runtime JARs (bootstrap externally from a reference .pak;
# see vcfops_managementpacks/README.md for instructions). Not distributed
# via the repo — these are VMware/Broadcom runtime binaries.
vcfops_managementpacks/adapter_runtime/
vcfops_managementpacks/adapter_runtime.stubs.bak/

# Local clones of external reference sources (see context/reference_sources.md)
references/

# SDK adapter paks are independently-versioned repos cloned here by
# scripts/bootstrap_managed_paks.sh (see context/managed_paks.md). They are
# NOT stored in the factory — each is its own repo with its own CI release.
content/sdk-adapters/

# Session scratchpads — workspace files, not part of the repo
tmp/
status.md
# Agent build/extract scratch that leaks into the repo root (pak unzip, jar checks)
scratch_*/
scratchpad/
.review-passed

# Memory layer — sessions are per-user and don't travel
memory/sessions/

# Local PKA comm zone (not shared)
.pka/
.claude/scheduled_tasks.lock

# Curation velocity counter — per-checkout, not shared (see designs/curator-v1.md)
context/curation/.sessions-since
