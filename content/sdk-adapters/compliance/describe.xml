<?xml version="1.0" encoding="UTF-8"?>
<AdapterKind xmlns="http://schemas.vmware.com/vcops/schema"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             key="vcfcf_compliance"
             nameKey="1"
             version="1"
             xsi:schemaLocation="http://schemas.vmware.com/vcops/schema describeSchema.xsd">

  <CredentialKinds>
    <CredentialKind key="vcenter_credentials" nameKey="2">
      <CredentialField key="username" nameKey="3" type="string"
                       required="true" dispOrder="1"/>
      <CredentialField key="password" nameKey="4" type="string"
                       required="true" password="true" dispOrder="2"/>
      <CredentialField key="ops_password" nameKey="33" type="string"
                       required="false" password="true" dispOrder="3"/>
    </CredentialKind>
  </CredentialKinds>

  <ResourceKinds>

    <ResourceKind key="vcfcf_compliance" nameKey="5" type="7"
                  credentialKind="vcenter_credentials"
                  monitoringInterval="60">
      <ResourceIdentifier key="vcenter_host" nameKey="6" type="string"
                          required="true" dispOrder="1"/>
      <ResourceIdentifier key="benchmark_profile" nameKey="7" type="string"
                          required="true" dispOrder="2" default="VMware_SCG_8.0"
                          enum="true">
        <enum value="VMware_SCG_8.0" displayOrder="1"/>
        <enum value="VMware_SCG_9.0" displayOrder="2"/>
        <enum value="CIS_vSphere_8" displayOrder="3"/>
        <enum value="Custom" displayOrder="4"/>
      </ResourceIdentifier>
      <ResourceIdentifier key="custom_profile_path" nameKey="8" type="string"
                          required="false" dispOrder="3" default=""/>
      <ResourceIdentifier key="allowInsecure" nameKey="9" type="string"
                          required="false" dispOrder="4" default="true"/>
      <ResourceIdentifier key="ops_host" nameKey="30" type="string"
                          required="false" dispOrder="5" default=""/>
      <ResourceIdentifier key="ops_user" nameKey="31" type="string"
                          required="false" dispOrder="6" default="admin"/>
      <ResourceIdentifier key="ops_auth_source" nameKey="32" type="string"
                          required="false" dispOrder="7" default="Local"/>
    </ResourceKind>

    <ResourceKind key="ComplianceWorld" nameKey="20" type="1">
      <ResourceIdentifier key="world_id" nameKey="21" type="string"
                          required="true" dispOrder="1"/>
      <ResourceGroup key="Summary" nameKey="22" instanced="false">
        <ResourceAttribute key="total_hosts" nameKey="23"
                           dataType="float" isProperty="false"
                           defaultMonitored="true"/>
        <ResourceAttribute key="avg_host_score" nameKey="24"
                           dataType="float" isProperty="false"
                           defaultMonitored="true" unit="%"/>
        <ResourceAttribute key="hosts_below_threshold" nameKey="25"
                           dataType="float" isProperty="false"
                           defaultMonitored="true"/>
        <ResourceAttribute key="profile_name" nameKey="26"
                           dataType="string" isProperty="true"/>
        <ResourceAttribute key="last_scan_timestamp" nameKey="27"
                           dataType="string" isProperty="true"/>
      </ResourceGroup>
    </ResourceKind>

  </ResourceKinds>

  <LicenseConfig enabled="false"/>

</AdapterKind>
