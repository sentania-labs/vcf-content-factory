    {"type":"text","id":"out_git_t","x":2170,"y":504,"width":580,"height":88,"text":"GIT / PR / FORK\nYAML source forever. Every artifact diffable, reviewable,\nshareable. Auto-memory is disabled by design — knowledge\nlives in the repo, not in a session.","originalText":"GIT / PR / FORK\nYAML source forever. Every artifact diffable, reviewable,\nshareable. Auto-memory is disabled by design — knowledge\nlives in the repo, not in a session.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#581c87","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":7032,"version":1,"versionNonce":7033,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

