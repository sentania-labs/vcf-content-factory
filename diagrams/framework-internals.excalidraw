    {"type":"text","id":"out_live_t","x":2170,"y":244,"width":580,"height":88,"text":"LIVE INSTALL\nSuite API push to a running VCF Operations instance.\nUUID-preserving content-zip import means cross-references\nsurvive between dev / qa / prod.","originalText":"LIVE INSTALL\nSuite API push to a running VCF Operations instance.\nUUID-preserving content-zip import means cross-references\nsurvive between dev / qa / prod.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":7012,"version":1,"versionNonce":7013,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

