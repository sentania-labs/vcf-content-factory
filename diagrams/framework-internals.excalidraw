    {"type":"text","id":"loop_s2_h","x":490,"y":1004,"width":320,"height":24,"text":"2. ROOT CAUSE","originalText":"2. ROOT CAUSE","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":8032,"version":1,"versionNonce":8033,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"loop_s2_b","x":490,"y":1036,"width":320,"height":146,"text":"Orchestrator + agents identify\nthe class of failure:\n\n  · framework gap\n  · agent over-interview\n  · wire-format invariant\n  · undocumented pattern\n\nNarrow to the smallest change.","originalText":"Orchestrator + agents identify\nthe class of failure:\n\n  · framework gap\n  · agent over-interview\n  · wire-format invariant\n  · undocumented pattern\n\nNarrow to the smallest change.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#1e3a8a","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":8034,"version":1,"versionNonce":8035,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

