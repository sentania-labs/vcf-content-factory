    {"type":"text","id":"tier1_label","x":1490,"y":236,"width":600,"height":22,"text":"TIER 1  ·  MPB pipeline (HTTP REST adapters)","originalText":"TIER 1  ·  MPB pipeline (HTTP REST adapters)","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#dcfce7","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":6014,"version":1,"versionNonce":6015,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"text","id":"tier1_flow","x":1500,"y":284,"width":580,"height":140,"text":"mp.yaml\n   ↓  render-export   (vcfops_managementpacks/render.py)\nexchange-format JSON   (design.json)\n   ↓  push-design        (Suite API import endpoint)\nMPB UI on devel  →  Source test  →  Verify   (CHEAP LOOP)\n   ↓  (green)\nrender + build         (template.json + describe.xml + adapter JAR)\n   ↓  pak-compare against MPB reference\n.pak  →  install","originalText":"mp.yaml\n   ↓  render-export   (vcfops_managementpacks/render.py)\nexchange-format JSON   (design.json)\n   ↓  push-design        (Suite API import endpoint)\nMPB UI on devel  →  Source test  →  Verify   (CHEAP LOOP)\n   ↓  (green)\nrender + build         (template.json + describe.xml + adapter JAR)\n   ↓  pak-compare against MPB reference\n.pak  →  install","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#14532d","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":6016,"version":1,"versionNonce":6017,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

