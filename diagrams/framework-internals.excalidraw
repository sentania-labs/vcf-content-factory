    {"type":"text","id":"out_zip_t","x":2170,"y":374,"width":580,"height":88,"text":"DISTRIBUTION ZIP\nself-installing bundle (Python + PowerShell) packaged with\nrendered wire format. Drop on a colleague's laptop, they run\npython3 install.py — works on any VCF Operations instance.","originalText":"DISTRIBUTION ZIP\nself-installing bundle (Python + PowerShell) packaged with\nrendered wire format. Drop on a colleague's laptop, they run\npython3 install.py — works on any VCF Operations instance.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#155e75","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":7022,"version":1,"versionNonce":7023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

