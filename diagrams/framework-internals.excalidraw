    {"type":"text","id":"loop_s1_h","x":90,"y":1004,"width":320,"height":24,"text":"1. CORRECTION","originalText":"1. CORRECTION","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#7c2d12","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":8022,"version":1,"versionNonce":8023,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},
    {"type":"text","id":"loop_s1_b","x":90,"y":1036,"width":320,"height":146,"text":"User catches a wrong-shaped\nrender, a misleading agent\nquestion, a missed pattern.\n\nIt arrives as a sentence:\n\n  > the components show up\n    flat — should be nested.","originalText":"User catches a wrong-shaped\nrender, a misleading agent\nquestion, a missed pattern.\n\nIt arrives as a sentence:\n\n  > the components show up\n    flat — should be nested.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#7c2d12","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":8024,"version":1,"versionNonce":8025,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

