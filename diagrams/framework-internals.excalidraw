    {"type":"text","id":"loop_s3_b","x":890,"y":1036,"width":320,"height":146,"text":"Write to the right place:\n\n  · context/rules_*.md\n  · context/lessons_*.md\n  · agent prompt updates\n  · context/api_pattern_catalog\n  · CLAUDE.md if cross-cutting\n\nAll diffable, all reviewable.","originalText":"Write to the right place:\n\n  · context/rules_*.md\n  · context/lessons_*.md\n  · agent prompt updates\n  · context/api_pattern_catalog\n  · CLAUDE.md if cross-cutting\n\nAll diffable, all reviewable.","fontSize":12,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#111827","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":8044,"version":1,"versionNonce":8045,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

