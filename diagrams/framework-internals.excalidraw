    {"type":"text","id":"tier2_label","x":1490,"y":456,"width":600,"height":22,"text":"TIER 2  ·  native Java SDK  (when MPB can't express it)","originalText":"TIER 2  ·  native Java SDK  (when MPB can't express it)","fontSize":13,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#f3e8ff","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":6024,"version":1,"versionNonce":6025,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

    {"type":"text","id":"tier2_flow","x":1500,"y":504,"width":580,"height":140,"text":"adapter.yaml  +  src/com/.../*.java\n   ↓  validate-sdk          (schema + javac sanity)\n   ↓  build-sdk             (compile, embed factory base JAR)\nadapter JAR  +  describe.xml emitted programmatically\n   ↓  pak-compare\n.pak  →  install\n\nReach for when MPB hits a wall  (hardware MPs, custom auth,\ninstanced groups, regex extraction, cross-request scalars)","originalText":"adapter.yaml  +  src/com/.../*.java\n   ↓  validate-sdk          (schema + javac sanity)\n   ↓  build-sdk             (compile, embed factory base JAR)\nadapter JAR  +  describe.xml emitted programmatically\n   ↓  pak-compare\n.pak  →  install\n\nReach for when MPB hits a wall  (hardware MPs, custom auth,\ninstanced groups, regex extraction, cross-request scalars)","fontSize":11,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#581c87","backgroundColor":"transparent","fillStyle":"solid","strokeWidth":1,"strokeStyle":"solid","roughness":0,"opacity":100,"angle":0,"seed":6026,"version":1,"versionNonce":6027,"isDeleted":false,"groupIds":[],"boundElements":null,"link":null,"locked":false,"containerId":null,"lineHeight":1.25},

