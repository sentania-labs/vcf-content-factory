{
  "autoMemoryEnabled": false,
  "env": {
    "PYTHONPATH": "src"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "scripts/bootstrap_references.sh 2>/dev/null || true",
            "timeout": 60000
          },
          {
            "type": "command",
            "command": "scripts/bootstrap_managed_paks.sh 2>/dev/null || true",
            "timeout": 60000
          },
          {
            "type": "command",
            "command": "scripts/curation_staleness_check.sh 2>/dev/null || true",
            "timeout": 15000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/validate-content.py\"",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
