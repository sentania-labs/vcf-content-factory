# Copy to .env and fill in. NEVER commit .env.
#
#   cp .env.example .env
#   chmod 600 .env
#   set -a; . ./.env; set +a   # load into the current shell before running claude
#
# Use a dedicated least-privilege service account, not a personal admin login.

export VCFOPS_HOST=vcfops.lab.example.com   # hostname only, no scheme, no /suite-api
export VCFOPS_USER=svc-claude-poc
export VCFOPS_PASSWORD='change-me'
export VCFOPS_AUTH_SOURCE=Local              # or the name of an LDAP/SSO source
export VCFOPS_VERIFY_SSL=false               # PoC lab only; set true (or unset) in prod
