# Copy to .env and fill in real credentials. NEVER commit .env.
#
#   cp .env.example .env
#   chmod 600 .env
#   set -a; . ./.env; set +a   # load into the current shell before running claude
#
# Three credential profiles — prod (read-only recon), qa (primary-lab admin),
# devel (destructive playground). See CLAUDE.md §"Two-lab policy" for the
# per-command default rules.

# --- VCF Operations: prod profile (primary lab, read-only) ---
export VCFOPS_PROD_HOST=vcfops.lab.example.com
export VCFOPS_PROD_USER=svc-claude-poc
export VCFOPS_PROD_PASSWORD='change-me'
export VCFOPS_PROD_AUTH_SOURCE=Local
export VCFOPS_PROD_VERIFY_SSL=false

# --- VCF Operations: qa profile (primary lab, admin — uninstall round-trips) ---
export VCFOPS_QA_HOST=vcfops.lab.example.com
export VCFOPS_QA_USER=admin
export VCFOPS_QA_PASSWORD='change-me'
export VCFOPS_QA_AUTH_SOURCE=Local
export VCFOPS_QA_VERIFY_SSL=false

# --- VCF Operations: devel profile (devel lab, admin — destructive playground) ---
export VCFOPS_DEVEL_HOST=vcfops-devel.lab.example.com
export VCFOPS_DEVEL_USER=admin
export VCFOPS_DEVEL_PASSWORD='change-me'
export VCFOPS_DEVEL_AUTH_SOURCE=Local
export VCFOPS_DEVEL_VERIFY_SSL=false

# Default active profile (prod / qa / devel).
# Per-command defaults (validate→prod, sync/delete→devel) override this only
# when VCFOPS_PROFILE is also unset. Setting VCFOPS_PROFILE in your shell
# session affects ALL invocations, including read-only ones.
export VCFOPS_PROFILE=prod

# --- Synology DSM (management pack development) ---
export SYNO_HOST=nas.lab.example.com          # hostname or IP
export SYNO_PORT=5001                         # HTTPS port (default 5001)
export SYNO_USER=svc-monitoring
export SYNO_PASSWORD='change-me'
export SYNO_VERIFY_SSL=false                  # self-signed cert on most NAS boxes
